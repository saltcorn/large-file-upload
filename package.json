{
  "name": "@saltcorn/large-file-upload",
  "version": "0.0.1",
  "description": "Large file upload fieldview for Saltcorn with an XHR progress bar",
  "main": "index.js",
  "dependencies": {
    "@saltcorn/markup": "^0.5.0",
    "@saltcorn/data": "^0.5.0"
  },
  "author": "Christian Hugoch",
  "license": "MIT",
  "repository": "github:saltcorn/large-file-upload",
  "eslintConfig": {
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 2020
    },
    "env": {
      "node": true,
      "es6": true
    },
    "rules": {
      "no-unused-vars": "off",
      "no-case-declarations": "off",
      "no-empty": "warn",
      "no-fallthrough": "warn"
    }
  }
}
